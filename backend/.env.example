# ---------------------------------------------------------------------------
# Organizer-issued OpenAI-compatible key (Priority)
# ---------------------------------------------------------------------------
ORGANIZER_API_KEY=your_organizer_key_here
ORGANIZER_API_BASE=https://api.openai.com/v1
ORGANIZER_CHAT_MODEL=gpt-4o
ORGANIZER_REASON_MODEL=gpt-5.4
ORGANIZER_EMBED_MODEL=text-embedding-3-large

# ---------------------------------------------------------------------------
# LLM backend fallback options
# ---------------------------------------------------------------------------

# Option A: Groq cloud (llama-3.3-70b-versatile is the default model)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Option B: Local vLLM server (used automatically when GROQ_API_KEY is unset)
VLLM_BASE_URL=http://localhost:8001/v1
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# ---------------------------------------------------------------------------
# Firebase Configuration
# ---------------------------------------------------------------------------
# Base64-encoded Service Account JSON (REQUIRED)
FIREBASE_SERVICE_ACCOUNT_JSON=your_base64_encoded_json_here
FIREBASE_STORAGE_BUCKET=your_bucket_name_here.appspot.com

# ---------------------------------------------------------------------------
# Infrastructure
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
LOKI_URL=http://loki:3100/loki/api/v1/push
UPLOAD_DIR=uploads
JWT_SECRET_KEY=your_jwt_secret_key_here
